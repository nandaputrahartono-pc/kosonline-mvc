+        $userId = (($_SESSION['status'] ?? null) === 'login_user' && isset($_SESSION['id_user']))
+            ? (int) $_SESSION['id_user']
+            : null;
+
         $this->render('room/invoice', [
             'invoice' => $invoice,
+            'bankAccounts' => require base_path('config/payment.php'),
+            'isOwner' => $userId !== null && $userId === (int) ($invoice['id_user'] ?? 0),
